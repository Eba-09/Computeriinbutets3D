{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.+\\.mp3)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable",
        "Accept-Ranges": "bytes"
      },
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.html)",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      },
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}